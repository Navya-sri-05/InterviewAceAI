# ----------------------------------------------------------------
# InterviewAce AI — Environment Configuration Template
# ----------------------------------------------------------------
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env (Windows)
# ----------------------------------------------------------------

# IBM Cloud API key — https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_api_key_here

# watsonx.ai Project ID — https://dataplatform.cloud.ibm.com
PROJECT_ID=your_project_id_here

# IBM watsonx.ai regional endpoint
IBM_URL=https://us-south.ml.cloud.ibm.com

# Flask secret key — change to a long random string in production
FLASK_SECRET_KEY=interviewace-secret-change-me
